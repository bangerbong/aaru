<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Day 1 - A Story About Us</title>
    <link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div id="app">
        <div id="scene-start" class="scene active bg-black">
            <div class="content-center">
                <p id="start-text" class="typewriter-text"></p>
                <button id="start-btn" class="pixel-btn hidden">Start</button>
            </div>
        </div>

        <div id="scene-game" class="scene hidden">
            <div class="sky">
                <div id="heart-container"></div>
            </div>
            <div class="ground"></div>

            <div id="girl" class="character girl">
                <div class="g-hair"></div>
                <div class="g-head"></div>
                <div class="g-body"></div>
                <div class="g-legs">
                    <div class="g-leg"></div>
                    <div class="g-leg"></div>
                </div>
            </div>

            <div id="dog" class="character dog out-of-screen">
                <div class="d-head">
                    <div class="d-ear"></div>
                    <div class="d-nose"></div>
                </div>
                <div class="d-body"></div>
                <div class="d-legs">
                    <div class="d-leg"></div>
                    <div class="d-leg"></div>
                </div>
                <div class="d-tail"></div>
            </div>

            <div id="envelope" class="hidden">💌</div>

            <div id="mobile-controls" class="hidden">
                <button id="btn-left" class="control-btn">◀</button>
                <button id="btn-right" class="control-btn">▶</button>
            </div>
        </div>

        <div id="scene-letter" class="scene overlay hidden">
            <div class="letter-box">
                <p id="letter-text" class="typewriter-text text-dark"></p>
                <button id="close-letter-btn" class="pixel-btn hidden">Continue</button>
            </div>
        </div>

        <div id="scene-end" class="scene hidden bg-black">
            <div class="content-center">
                <p class="fade-in-text">Day 2 is locked.<br><br>Come back tomorrow.</p>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
